        }

        .admin-sidebar::before {
            content: "";
            position: fixed;
            left: 0;
            top: 0;
            width: 280px;
            height: 100vh;
            pointer-events: none;
            background-image:
                linear-gradient(rgba(125, 211, 252, 0.055) 1px, transparent 1px),
                linear-gradient(90deg, rgba(125, 211, 252, 0.055) 1px, transparent 1px);
            background-size: 34px 34px;
            mask-image: linear-gradient(to bottom, rgba(0,0,0,.85), transparent 90%);
        }

        .admin-brand {
            position: relative;
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 0.8rem;
            margin-bottom: 1.35rem;
            border: 1px solid rgba(125, 211, 252, 0.18);
