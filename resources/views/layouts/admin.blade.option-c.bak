        }

        .admin-shell {
            min-height: 100vh;
            display: flex;
            background:
                radial-gradient(circle at 12% 12%, rgba(56, 189, 248, 0.15), transparent 30%),
                radial-gradient(circle at 92% 72%, rgba(240, 93, 179, 0.14), transparent 34%),
                linear-gradient(135deg, #020617 0%, #050816 48%, #090b1f 100%);
        }

        .admin-sidebar {
            width: 280px;
            min-height: 100vh;
            color: var(--admin-text);
            position: fixed;
            left: 0;
            top: 0;
            bottom: 0;
            padding: 1.25rem;
            overflow-y: auto;
            z-index: 1000;
            background:
                linear-gradient(180deg, rgba(2, 6, 23, 0.96), rgba(8, 13, 31, 0.94)),
                radial-gradient(circle at top left, rgba(56, 189, 248, 0.20), transparent 38%),
                radial-gradient(circle at bottom right, rgba(240, 93, 179, 0.16), transparent 42%);
            border-right: 1px solid rgba(125, 211, 252, 0.16);
            box-shadow:
                18px 0 60px rgba(0, 0, 0, 0.32),
                inset -1px 0 0 rgba(255, 255, 255, 0.03);
