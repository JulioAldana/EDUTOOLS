        .admin-main {
            margin-left: 280px;
            width: calc(100% - 280px);
            min-height: 100vh;
        }

        .admin-topbar {
            min-height: 76px;
            background:
                linear-gradient(135deg, rgba(2, 6, 23, 0.88), rgba(8, 13, 31, 0.80)),
                radial-gradient(circle at top right, rgba(56, 189, 248, 0.12), transparent 36%);
            backdrop-filter: blur(18px);
