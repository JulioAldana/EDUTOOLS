        @media (max-width: 991.98px) {
            .admin-sidebar {
                position: relative;
                width: 100%;
                min-height: auto;
                border-radius: 0 0 28px 28px;
            }

            .admin-sidebar::before {
                width: 100%;
                height: 280px;
            }

            .admin-shell {
                display: block;
            }

            .admin-main {
                margin-left: 0;
                width: 100%;
            }

            .admin-topbar {
                position: relative;
                flex-direction: column;
                align-items: flex-start;
                gap: 1rem;
            }
        }
    </style>
</head>

