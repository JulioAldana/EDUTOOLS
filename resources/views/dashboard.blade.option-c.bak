    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const chartElement = document.querySelector('#academicActivityChart');

            const chartLabels = @json($chartData['labels']);
            const chartValues = @json($chartData['values']);

            if (chartElement && window.ApexCharts) {
                const options = {
                    chart: {
                        type: 'bar',
                        height: 360,
                        toolbar: { show: false },
                        background: 'transparent',
                        animations: {
                            enabled: true,
                            easing: 'easeinout',
                            speed: 900
                        }
                    },
                    series: [
                        {
                            name: 'Registros activos',
                            data: chartValues
                        }
                    ],
                    colors: ['#8f79ff'],
                    xaxis: {
                        categories: chartLabels,
                        labels: {
                            style: {
                                colors: '#5b6477',
                                fontWeight: 700
                            }
                        },
                        axisBorder: { show: false },
                        axisTicks: { show: false }
                    },
                    yaxis: {
                        labels: {
                            style: {
                                colors: '#5b6477',
                                fontWeight: 700
                            }
                        }
                    },
                    plotOptions: {
                        bar: {
                            borderRadius: 10,
                            columnWidth: '48%',
                            distributed: true
                        }
                    },
                    fill: {
                        type: 'gradient',
                        gradient: {
                            shade: 'light',
                            type: 'vertical',
                            shadeIntensity: 0.2,
                            gradientToColors: ['#f05db3'],
                            inverseColors: false,
                            opacityFrom: 0.95,
                            opacityTo: 0.70
                        }
                    },
                    dataLabels: {
                        enabled: true,
                        style: {
                            colors: ['#101828'],
                            fontWeight: 900
                        },
                        background: {
                            enabled: true,
                            foreColor: '#101828',
                            borderRadius: 8,
                            opacity: 0.65
                        }
                    },
                    grid: {
                        borderColor: 'rgba(255,255,255,.42)',
                        strokeDashArray: 6
                    },
                    tooltip: {
                        theme: 'light',
                        y: {
                            formatter: function (value) {
                                return value + ' registros';
                            }
                        }
                    },
                    legend: {
                        show: false
                    }
                };

                const chart = new ApexCharts(chartElement, options);
                chart.render();
            }
        });
    </script>
@endsection